{
  "version": 2,
  "regions": ["fra1"],
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": [
          "data/es-titles-index.json",
          "data/gs-titles-index.json",
          "data/gs-episodes-index.json",
          "data/kk-titles-index.json",
          "data/kk-episodes-index.json",
          "data/rama-titles-index.json",
          "data/loonex-titles-index.json",
          "data/loonex-episodes-index.json"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.js" }
  ],
  "crons": [
    { "path": "/api/cron/warm-uprot",     "schedule": "0 3 * * *" },
    { "path": "/api/cron/domain-health",  "schedule": "0 6 * * *" },
    { "path": "/api/cron/gs-index-push",  "schedule": "0 4 * * *" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
