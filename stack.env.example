# ── StreamFusion Mail — WireGuard + Environment Config EXAMPLE ──────────────
# Copia questo file in stack.env e compila con le tue credenziali reali.
# Uso: docker compose --env-file stack.env up -d

# ── WireGuard VPN (Gluetun) ───────────────────────────────────────────────────
VPN_ENDPOINT_IP=
VPN_ENDPOINT_PORT=51820
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_DNS=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=

# ── Proxy HTTP (gost) — credenziali per autenticazione ───────────────────────
# Usati per proteggere il proxy esposto su internet
# Imposta la stessa password in Vercel: PROXY_URL=http://USER:PASS@TUO_IP:8118
PROXY_USER=sfmail
PROXY_PASS=

# ── Cloudflare Worker proxy per KissKH ───────────────────────────────────────
# CF Worker bypassa il Cloudflare Bot Management di kisskh.co perché gira
# direttamente sulla rete Cloudflare — nessun CAPTCHA/JS challenge.
#
# Come deployare il Worker:
#   1. https://dash.cloudflare.com → Workers & Pages → Create → Hello World
#   2. Incolla il contenuto di cfworker.js (nella root del progetto) → Save & Deploy
#   3. In Worker Settings → Variables → aggiungi AUTH_TOKEN = (valore random sicuro)
#   4. Imposta le stesse variabili in Vercel:
#        CF_WORKER_URL  = https://kisskh-proxy.xxx.workers.dev
#        CF_WORKER_AUTH = <stesso valore AUTH_TOKEN>
#
# Il Worker è il tentativo #0 (prima di FlareSolverr e axios) per catalog, meta e stream.
CF_WORKER_URL=
CF_WORKER_AUTH=

# ── TMDB API key (server-level fallback) ─────────────────────────────────────
# Opzionale: usato come fallback quando Cinemeta non restituisce titoli per i
# K-drama (i datacenter Vercel sono spesso esclusi da v3-cinemeta.strem.io).
# Ottieni una chiave gratuita su: https://developer.themoviedb.org/docs
# In alternativa, configura il tuo tmdbKey nel'URL del manifest Stremio.
TMDB_API_KEY=
