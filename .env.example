# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info   # debug | info | warn | error

# Timeouts (milliseconds)
CATALOG_TIMEOUT=20000
META_TIMEOUT=30000
STREAM_TIMEOUT=45000

# Cloudflare bypass (kisskh.co)
CF_COOKIE_MAX_AGE=3600000    # 1 hour
CF_MAX_RETRY=3
CF_RETRY_DELAY=5000          # base delay (exponential backoff applied)

# Puppeteer — @sparticuz/chromium gestisce il binary automaticamente su Vercel.
# Imposta solo se usi un Chromium custom (Docker/Linux con chromium pre-installato).
# Lascia vuoto per sviluppo locale (rileva Chrome di sistema).
PUPPETEER_EXECUTABLE_PATH=
